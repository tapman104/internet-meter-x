<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════ DARK (default) ═══════════════════════════════ -->
    <style name="Theme_InternetSpeedMeterLite" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
    </style>

    <style name="Theme_InternetMeterX_Settings" parent="Theme_InternetSpeedMeterLite">
        <item name="android:windowBackground">@color/settings_bg</item>
        <item name="android:statusBarColor">@color/settings_bg</item>
        <item name="android:navigationBarColor">@color/settings_bg</item>
    </style>

    <!-- ═══════════════════════════════ LIGHT ═══════════════════════════════════════ -->
    <style name="Theme_InternetSpeedMeterLite_Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:statusBarColor">@color/light_background</item>
        <item name="android:navigationBarColor">@color/light_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/light_on_surface_variant</item>
    </style>

    <style name="Theme_InternetMeterX_Settings_Light" parent="Theme_InternetSpeedMeterLite_Light">
        <item name="android:windowBackground">@color/light_settings_bg</item>
        <item name="android:statusBarColor">@color/light_settings_bg</item>
        <item name="android:navigationBarColor">@color/light_settings_bg</item>
        <!-- Ensure surface color is correct for settings -->
        <item name="colorSurface">@color/light_settings_bg</item>
    </style>

    <!-- ═══════════════════════════════ MATERIAL YOU (Dynamic) ══════════════════════ -->
    <!-- Base theme for Material You extending Theme.Material3.DynamicColors.DayNight -->
    <style name="Theme_InternetSpeedMeterLite_MaterialYou" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <style name="Theme_InternetMeterX_Settings_MaterialYou" parent="Theme_InternetSpeedMeterLite_MaterialYou">
        <item name="android:windowBackground">@color/settings_bg</item>
        <item name="android:statusBarColor">@color/settings_bg</item>
        <item name="android:navigationBarColor">@color/settings_bg</item>
    </style>

</resources>
