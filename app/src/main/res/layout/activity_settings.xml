<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/settings_bg">

    <!-- Navigation Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nav_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/status_dot"
            android:backgroundTint="#222222"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back_arrow" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Settings"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/settings_divider"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nav_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Display Section -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:text="DISPLAY" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical">

                <!-- Show speed in bits -->
                <include
                    android:id="@+id/row_bits"
                    layout="@layout/layout_settings_row_toggle" />

                <View style="@style/SettingsDivider" />

                <!-- Data unit precision -->
                <include
                    android:id="@+id/row_precision"
                    layout="@layout/layout_settings_row_value" />

            </LinearLayout>

            <!-- Service Section -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:layout_marginTop="24dp"
                android:text="SERVICE" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_boot"
                    layout="@layout/layout_settings_row_toggle" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/row_background"
                    layout="@layout/layout_settings_row_toggle" />

            </LinearLayout>

            <!-- Notifications Section -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:layout_marginTop="24dp"
                android:text="NOTIFICATIONS" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical">

                <include
                    android:id="@+id/row_priority"
                    layout="@layout/layout_settings_row_toggle" />

                <View style="@style/SettingsDivider" />

                <include
                    android:id="@+id/row_alert"
                    layout="@layout/layout_settings_row_value" />

            </LinearLayout>

            <!-- About Section -->
            <TextView
                style="@style/SettingsSectionLabel"
                android:layout_marginTop="24dp"
                android:text="ABOUT" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_card"
                android:orientation="vertical">

                <!-- Version -->
                <include
                    android:id="@+id/row_version"
                    layout="@layout/layout_settings_row_value" />

                <View style="@style/SettingsDivider" />

                <!-- Reset -->
                <include
                    android:id="@+id/row_reset"
                    layout="@layout/layout_settings_row_value" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>